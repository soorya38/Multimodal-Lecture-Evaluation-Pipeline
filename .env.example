# ---------------------------------------------------------------------------
# Multimodal Lecture Evaluation Pipeline — example configuration
# Copy to .env and adjust. All values below are the built-in defaults.
# ---------------------------------------------------------------------------

# --- General ---
LOG_LEVEL=INFO
PORT=8000

# --- MinIO object storage ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_DEFAULT_BUCKET=lectures

# --- Whisper transcription ---
# device: cuda (GPU) | cpu | auto      compute_type: float16 (GPU) | int8 (CPU) | default
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_MODEL_SIZE=large-v3
WHISPER_CPU_THREADS=0        # 0 = use all available cores

# --- LLM provider for OCR + evaluation ---
# ollama  -> local Ollama server (default, fully self-hosted)
# openai  -> any OpenAI-compatible /chat/completions endpoint
#            (OpenAI, vLLM, Together, LM Studio, Ollama's own /v1, ...)
LLM_PROVIDER=ollama

# Ollama transport (used when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434

# OpenAI-compatible transport (used when LLM_PROVIDER=openai)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Models (LLM_* are canonical; legacy OLLAMA_* names still accepted)
LLM_EVAL_MODEL=llama3.2
LLM_OCR_MODEL=llava-phi3

# Sampling / determinism
LLM_EVAL_SEED=42
LLM_EVAL_TEMPERATURE=0.1
LLM_OCR_TEMPERATURE=0.0

# Concurrency + resilience
OCR_MAX_WORKERS=0            # 0 = scale with CPUs, capped at 8
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2
